rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /blood_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if isValidPublicCreate();
      allow update: if request.auth != null && isValidVolunteerUpdate();
      allow delete: if request.auth != null && isAdmin();
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /volunteers/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId && isValidVolunteerDoc();
      allow update: if request.auth != null && (
          (request.auth.uid == userId && isValidVolunteerDoc()) ||
          (isAdmin() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['approved','approvedBy','approvedByUid','approvedAt','updatedAt'])));
      allow delete: if request.auth != null && isAdmin();
    }

    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // create admin docs manually via Console
    }

    // ─────────────────────────────────────────────────────────
    // CREATE — public intake (unauthenticated)
    // ─────────────────────────────────────────────────────────
    function isValidPublicCreate() {
      let data = request.resource.data;
      return data.keys().hasAll([
          'patientName', 'gender', 'age', 'bloodGroup', 'primaryMobile',
          'hospitalName', 'area', 'pcvUnits', 'ffpUnits', 'sdpUnits',
          'requiredBefore', 'status', 'createdAt', 'updatedAt'
        ])
        && data.patientName is string && data.patientName.size() > 0 && data.patientName.size() <= 100
        && data.gender in ['Male', 'Female']
        && data.age is int && data.age >= 0 && data.age <= 150
        && data.bloodGroup in ['A+','A-','B+','B-','AB+','AB-','O+','O-']
        && data.primaryMobile is string && data.primaryMobile.matches('^[0-9]{10}$')
        && (!('alternateMobile' in data) || data.alternateMobile == null || data.alternateMobile == ''
              || (data.alternateMobile is string && data.alternateMobile.matches('^[0-9]{10}$')))
        && data.hospitalName is string && data.hospitalName.size() > 0 && data.hospitalName.size() <= 150
        && (!('referenceBy' in data) || data.referenceBy == null
              || (data.referenceBy is string && data.referenceBy.size() <= 100))
        && data.pcvUnits is int && data.pcvUnits >= 0 && data.pcvUnits <= 99
        && data.ffpUnits is int && data.ffpUnits >= 0 && data.ffpUnits <= 99
        && data.sdpUnits is int && data.sdpUnits >= 0 && data.sdpUnits <= 99
        && (data.pcvUnits + data.ffpUnits + data.sdpUnits) > 0
        && data.requiredBefore is timestamp
        && (!('remarks' in data) || data.remarks == null
              || (data.remarks is string && data.remarks.size() <= 500))
        && data.status == 'open'
        && (!('claimedBy' in data) || data.claimedBy == null)
        && (!('claimedByUid' in data) || data.claimedByUid == null)
        && (!('claimedAt' in data) || data.claimedAt == null)
        && (!('completionNotes' in data) || data.completionNotes == null || data.completionNotes == '')
        && (!('completedAt' in data) || data.completedAt == null)
        && (!('rejectedBy' in data) || data.rejectedBy == null)
        && (!('rejectedByUid' in data) || data.rejectedByUid == null)
        && (!('rejectedAt' in data) || data.rejectedAt == null)
        && (!('rejectionReason' in data) || data.rejectionReason == null)
        && (!('rejectionNote' in data) || data.rejectionNote == null || data.rejectionNote == '')
        && (!('bloodBankName' in data) || data.bloodBankName == null)
        && data.createdAt is timestamp && data.createdAt == request.time
        && data.updatedAt is timestamp && data.updatedAt == request.time;
    }

    // ─────────────────────────────────────────────────────────
    // UPDATE — volunteer app (authenticated)
    // ─────────────────────────────────────────────────────────
    function isValidVolunteerUpdate() {
      return isClaimTransition()
        || isDropTransition()
        || isOnTheWayTransition()
        || isDoneTransition()
        || isRejectTransition()
        || isFieldEditTransition();
    }

    // Fields a status-change action is allowed to touch.
    function statusMutableFields() {
      return [
        'status', 'claimedBy', 'claimedByUid', 'claimedAt', 'updatedAt',
        'completionNotes', 'completedAt',
        'rejectedBy', 'rejectedByUid', 'rejectedAt', 'rejectionReason', 'rejectionNote'
      ];
    }

    // Fields a plain "edit details" save is allowed to touch.
    // Mirrors REQUEST_SCHEMA fields + the editable JOB_SCHEMA field (bloodBankName).
    function editableDetailFields() {
      return [
        'patientName', 'gender', 'age', 'bloodGroup', 'primaryMobile', 'alternateMobile',
        'hospitalName', 'area', 'referenceBy',
        'pcvUnits', 'ffpUnits', 'sdpUnits', 'requiredBefore',
        'remarks', 'bloodBankName', 'updatedAt'
      ];
    }

    function onlyStatusFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(statusMutableFields());
    }

    function onlyDetailFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(editableDetailFields());
    }

    function isClaimTransition() {
      return onlyStatusFieldsChanged()
        && resource.data.status == 'open'
        && request.resource.data.status == 'claimed'
        && request.resource.data.claimedByUid == request.auth.uid
        && request.resource.data.claimedBy is string
        && request.resource.data.claimedBy.size() > 0
        && request.resource.data.claimedBy.size() <= 100
        && request.resource.data.claimedAt is timestamp
        && request.resource.data.claimedAt == request.time
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time
        && request.resource.data.completedAt == resource.data.completedAt
        && request.resource.data.completionNotes == resource.data.completionNotes;
    }

    function isDropTransition() {
      return onlyStatusFieldsChanged()
        && resource.data.status == 'claimed'
        && resource.data.claimedByUid == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.claimedBy == null
        && request.resource.data.claimedByUid == null
        && request.resource.data.claimedAt == null
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time
        && request.resource.data.completedAt == resource.data.completedAt
        && request.resource.data.completionNotes == resource.data.completionNotes;
    }

    function isOnTheWayTransition() {
      return onlyStatusFieldsChanged()
        && resource.data.status == 'claimed'
        && resource.data.claimedByUid == request.auth.uid
        && request.resource.data.status == 'on_the_way'
        && request.resource.data.claimedByUid == request.auth.uid
        && request.resource.data.claimedBy == resource.data.claimedBy
        && request.resource.data.claimedAt == resource.data.claimedAt
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time
        && request.resource.data.completedAt == resource.data.completedAt
        && request.resource.data.completionNotes == resource.data.completionNotes;
    }

    function isDoneTransition() {
      return onlyStatusFieldsChanged()
        && resource.data.status in ['claimed', 'on_the_way']
        && resource.data.claimedByUid == request.auth.uid
        && request.resource.data.status == 'done'
        && request.resource.data.claimedByUid == request.auth.uid
        && request.resource.data.claimedBy == resource.data.claimedBy
        && request.resource.data.claimedAt == resource.data.claimedAt
        && request.resource.data.completionNotes is string
        && request.resource.data.completionNotes.size() <= 1000
        && request.resource.data.completedAt is timestamp
        && request.resource.data.completedAt == request.time
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time;
    }

    // New: covers JOB_SCHEMA's "rejected" status, which had no transition before.
    function isRejectTransition() {
      return onlyStatusFieldsChanged()
        && resource.data.status == 'open'
        && request.resource.data.status == 'rejected'
        && request.resource.data.rejectedByUid == request.auth.uid
        && request.resource.data.rejectedBy is string
        && request.resource.data.rejectedBy.size() > 0
        && request.resource.data.rejectedBy.size() <= 100
        && request.resource.data.rejectionReason is string
        && request.resource.data.rejectionReason.size() <= 200
        && request.resource.data.rejectedAt is timestamp
        && request.resource.data.rejectedAt == request.time
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time
        && request.resource.data.claimedBy == resource.data.claimedBy
        && request.resource.data.claimedByUid == resource.data.claimedByUid
        && request.resource.data.claimedAt == resource.data.claimedAt
        && request.resource.data.completedAt == resource.data.completedAt
        && request.resource.data.completionNotes == resource.data.completionNotes;
    }

    // New: covers the "Save" edit-mode button, which changes request/job
    // details without changing status. Only the current claimer may edit
    // once a request is claimed; anyone signed in may correct an open one.
    function isFieldEditTransition() {
      return onlyDetailFieldsChanged()
        && request.resource.data.status == resource.data.status
        && (resource.data.status == 'open' || resource.data.claimedByUid == request.auth.uid)
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time
        && request.resource.data.age is int
        && request.resource.data.pcvUnits is int
        && request.resource.data.ffpUnits is int
        && request.resource.data.sdpUnits is int;
    }

    function isValidVolunteerDoc() {
      let data = request.resource.data;
      return data.keys().hasOnly(['displayName', 'email', 'fcmToken', 'createdAt', 'updatedAt'])
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('email' in data) || (data.email is string && data.email.size() <= 200))
        && (!('fcmToken' in data) || (data.fcmToken is string && data.fcmToken.size() <= 4096))
        && (!('createdAt' in data) || data.createdAt is timestamp)
        && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }
  }
}